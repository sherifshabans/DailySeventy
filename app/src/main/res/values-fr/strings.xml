    <!-- Notifications -->
    <string name="notifications_title">Activer les notifications</string>
    <string name="notifications_subtitle">Pour recevoir les rappels des adhkars et des heures de prière</string>
    <string name="notifications_step1">Allez dans Paramètres → Notifications</string>
    <string name="notifications_step2">Recherchez l’application "Soixante-dix fois" et activez-la</string>
    <string name="notifications_step3">Assurez-vous que tous les types de notifications sont activés</string>

    <!-- Overlay -->
    <string name="overlay_title">Autoriser l’affichage au-dessus des applications</string>
    <string name="overlay_subtitle">Pour afficher les rappels d’adhkars même lors de l’utilisation d’autres applications</string>
    <string name="overlay_step1">Allez dans Paramètres → Applications spéciales</string>
    <string name="overlay_step2">Choisissez "Apparaître au-dessus des autres applications"</string>
    <string name="overlay_step3">Recherchez "Soixante-dix fois" et activez l’option</string>

    <!-- Capteurs -->
    <string name="sensors_title">Activer les capteurs de l’appareil</string>
    <string name="sensors_subtitle">Pour utiliser les capteurs de lumière et de mouvement dans les rappels intelligents</string>
    <string name="sensors_step1">Allez dans Paramètres → Confidentialité</string>
    <string name="sensors_step2">Sélectionnez "Autorisations administrateur" → Capteurs</string>
    <string name="sensors_step3">Assurez-vous d’autoriser l’application "Soixante-dix fois"</string>

    <!-- Batterie -->
    <string name="battery_title">Optimisation de la batterie</string>
    <string name="battery_subtitle">Pour garantir le fonctionnement de l’application en arrière-plan sans interruption</string>
    <string name="battery_step1">Allez dans Paramètres → Batterie</string>
    <string name="battery_step2">Choisissez "Optimiser l’utilisation de la batterie"</string>
    <string name="battery_step3">Recherchez "Soixante-dix fois" et choisissez "Ne pas optimiser"</string>

    <string name="permissions_note">Ces étapes sont nécessaires pour une expérience optimale avec l’application. Les noms des menus peuvent varier selon la version du système.</string>


