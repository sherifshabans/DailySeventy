    <string name="open_settings">Open Settings</string>

    <!-- Notifications -->
    <string name="notifications_title">Enable Notifications</string>
    <string name="notifications_subtitle">To receive reminders for adhkar and prayer times</string>
    <string name="notifications_step1">Go to Settings → Notifications</string>
    <string name="notifications_step2">Find the "Seventy Times" app and enable it</string>
    <string name="notifications_step3">Make sure all types of notifications are enabled</string>

    <!-- Overlay -->
    <string name="overlay_title">Allow Overlay</string>
    <string name="overlay_subtitle">To show adhkar reminders while using other apps</string>
    <string name="overlay_step1">Go to Settings → Special Apps</string>
    <string name="overlay_step2">Select "Appear on top of other apps"</string>
    <string name="overlay_step3">Find "Seventy Times" and enable the option</string>

    <!-- Sensors -->
    <string name="sensors_title">Enable Device Sensors</string>
    <string name="sensors_subtitle">To use light and motion sensors for smart reminders</string>
    <string name="sensors_step1">Go to Settings → Privacy</string>
    <string name="sensors_step2">Select "Admin Permissions" → Sensors</string>
    <string name="sensors_step3">Make sure to allow "Seventy Times" app</string>

    <!-- Battery -->
    <string name="battery_title">Battery Optimization</string>
    <string name="battery_subtitle">To ensure the app works in the background without interruption</string>
    <string name="battery_step1">Go to Settings → Battery</string>
    <string name="battery_step2">Select "Optimize battery usage"</string>
    <string name="battery_step3">Find "Seventy Times" and choose "Don’t optimize"</string>

    <string name="permissions_note">These steps are necessary for the best experience with the app. Menu names may vary depending on the OS version.</string>



